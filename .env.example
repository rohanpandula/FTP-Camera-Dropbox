FTP_USER=cameras
FTP_PASS=cameras
PUBLICHOST=10.0.0.101         # IP the FTP server advertises in PASV (your host IP or container IP)
DATA_DIR=./data               # only used if you switch to the bind-mount option in docker-compose.yml
STABLE_WAIT=60
NOTIFY_INTERVAL=300
RAW_FULL_VALIDATE=1         # 1 = run LibRaw decode before sorting RAWs; set 0 to disable
RAW_VALIDATE_TIMEOUT=240    # seconds allowed for raw-identify/simple_dcraw validation

# --- Optional: Frame.io Camera-to-Cloud mirror ---
# Only consumed when you bring up the `frameio-mirror` profile:
#   docker compose --profile frameio up -d
#
# All four are optional. Without any of them, the mirror still receives
# webhooks and downloads via the pre-signed URL Frame.io includes in the
# payload. You only need Adobe creds if you want auto-delete from Frame.io
# (to keep the 2 GB free-tier quota clear).
#
# FRAMEIO_WEBHOOK_SECRET=     # From Frame.io webhook settings — enables HMAC-SHA256 signature verification
# ADOBE_CLIENT_ID=            # Adobe Developer Console → Frame.io API → Server-to-Server OAuth credential
# ADOBE_CLIENT_SECRET=        # ditto
# ADOBE_SCOPES=openid,AdobeID,additional_info.roles,offline_access,profile,email  # offline_access REQUIRED for refresh token
# OAUTH_REDIRECT_URI=https://YOUR_PUBLIC_HOSTNAME/oauth/callback  # MUST match what you register in Adobe Dev Console
